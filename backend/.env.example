# Database
DATABASE_URL=postgres://user:password@localhost:5432/alert_system

# External APIs
OPENWEATHER_API_KEY=your_openweather_api_key
AIR_QUALITY_API_KEY=your_air_quality_api_key
SEOUL_BUS_API_KEY=your_seoul_bus_api_key
SEOUL_SUBWAY_API_KEY=your_seoul_subway_api_key

# Push Notifications (Web Push)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Alimtalk Provider: 'nhn' or 'kakao'
ALIMTALK_PROVIDER=nhn

# NHN Cloud Alimtalk (https://www.nhncloud.com/)
NHN_APP_KEY=your_nhn_app_key
NHN_SECRET_KEY=your_nhn_secret_key
NHN_SENDER_KEY=your_nhn_sender_key

# Kakao Alimtalk (https://business.kakao.com/)
KAKAO_API_KEY=your_kakao_api_key
KAKAO_API_SECRET=your_kakao_api_secret
KAKAO_SENDER_KEY=your_kakao_sender_key
KAKAO_PF_ID=your_kakao_plus_friend_id
